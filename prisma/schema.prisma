// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// AUTH (NextAuth.js required models)
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// CORE ENTITIES
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // App relations
  profile           Profile?
  memberships       Membership[]
  ownedCommunities  Community[]       @relation("CommunityOwner")
  matchesAsA        Match[]           @relation("MatchUserA")
  matchesAsB        Match[]           @relation("MatchUserB")
  helpRequests      HelpRequest[]
  helpResponses     HelpResponse[]
  connectionsAsA    Connection[]      @relation("ConnectionUserA")
  connectionsAsB    Connection[]      @relation("ConnectionUserB")
  buddyAssignments  BuddyAssignment[] @relation("NewUser")
  buddyOf           BuddyAssignment[] @relation("BuddyUser")
  interactionsActor Interaction[]     @relation("InteractionActor")
  interactionsTarget Interaction[]    @relation("InteractionTarget")
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  bio       String?
  goals     String?
  timezone  String   @default("UTC")
  skills    String[]
  interests String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Community {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  ownerId     String
  healthScore Float    @default(50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner           User              @relation("CommunityOwner", fields: [ownerId], references: [id])
  memberships     Membership[]
  matches         Match[]
  helpRequests    HelpRequest[]
  buddyAssignments BuddyAssignment[]
  interactions    Interaction[]
}

model Membership {
  id          String         @id @default(cuid())
  userId      String
  communityId String
  role        MembershipRole @default(MEMBER)
  joinedAt    DateTime       @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@unique([userId, communityId])
}

model Match {
  id          String      @id @default(cuid())
  userAId     String
  userBId     String
  communityId String
  status      MatchStatus @default(PENDING)
  score       Float       @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  userA      User      @relation("MatchUserA", fields: [userAId], references: [id])
  userB      User      @relation("MatchUserB", fields: [userBId], references: [id])
  community  Community @relation(fields: [communityId], references: [id])

  @@unique([userAId, userBId, communityId])
}

model HelpRequest {
  id          String            @id @default(cuid())
  authorId    String
  communityId String
  title       String
  description String            @db.Text
  tags        String[]
  status      HelpRequestStatus @default(OPEN)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  author    User           @relation(fields: [authorId], references: [id])
  community Community      @relation(fields: [communityId], references: [id])
  responses HelpResponse[]
}

model HelpResponse {
  id         String   @id @default(cuid())
  requestId  String
  helperId   String
  message    String   @db.Text
  createdAt  DateTime @default(now())

  request HelpRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  helper  User        @relation(fields: [helperId], references: [id])
}

model Connection {
  id        String         @id @default(cuid())
  userAId   String
  userBId   String
  type      ConnectionType
  weight    Float          @default(1)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  userA User @relation("ConnectionUserA", fields: [userAId], references: [id])
  userB User @relation("ConnectionUserB", fields: [userBId], references: [id])

  @@unique([userAId, userBId, type])
}

model BuddyAssignment {
  id          String   @id @default(cuid())
  newUserId   String
  buddyUserId String
  communityId String
  createdAt   DateTime @default(now())

  newUser   User      @relation("NewUser", fields: [newUserId], references: [id])
  buddy     User      @relation("BuddyUser", fields: [buddyUserId], references: [id])
  community Community @relation(fields: [communityId], references: [id])
}

model Interaction {
  id          String          @id @default(cuid())
  type        InteractionType
  actorId     String
  targetId    String
  communityId String
  metadata    Json?
  timestamp   DateTime        @default(now())

  actor     User      @relation("InteractionActor", fields: [actorId], references: [id])
  target    User      @relation("InteractionTarget", fields: [targetId], references: [id])
  community Community @relation(fields: [communityId], references: [id])

  @@index([communityId, timestamp])
  @@index([actorId])
  @@index([targetId])
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum MembershipRole {
  MEMBER
  ADMIN
}

enum MatchStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum HelpRequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum ConnectionType {
  MATCH
  HELP
  BUDDY
  CHAT
}

enum InteractionType {
  MATCH
  HELP
  MESSAGE
  INTRODUCTION
  BUDDY_ASSIGNED
}
